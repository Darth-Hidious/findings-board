SESSION_SECRET=

# GitHub (fine-grained PAT; Contents:Read on needed repos)
GITHUB_TOKEN=

# xAI Grok — drafts threads
XAI_API_KEY=
XAI_MODEL=grok-3-mini

# X / Twitter API (leave empty for dry-run)
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
X_BEARER_TOKEN=

# Keep false until the voice is trusted
AUTO_POST=false
